{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Helium",
    "scopeName": "source.helium",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#objects" },
        { "include": "#lists" },
        { "include": "#functions" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [{
                "name": "comment.line.number-sign.helium",
                "match": "#.*$"
            }]
        },
        "keywords": {
            "patterns": [{
                "name": "keyword.control.helium",
                "match": "\\b(if|else|return|func)\\b"
            }]
        },
        "strings": {
            "patterns": [{
                "name": "string.quoted.double.helium",
                "begin": "\"",
                "end": "\"",
                "patterns": [{
                    "name": "constant.character.escape.helium",
                    "match": "\\\\."
                }]
            }]
        },
        "numbers": {
            "patterns": [{
                "name": "constant.numeric.helium",
                "match": "\\b\\d+(\\.\\d+)?\\b"
            }]
        },
        "functions": {
            "patterns": [
                {
                    "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "keyword.control.helium" },
                        "2": { "name": "entity.name.function.helium" }
                    }
                },
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.helium" }
                    }
                }
            ]
        },
        "variables": {
            "patterns": [{
                "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                "name": "variable.name.helium"
            }]
        }
    }
}
